# Set default behavior to auto-normalize line endings
* text=auto

# Source code
*.cs text diff=csharp
*.ts text
*.js text
*.html text
*.scss text
*.css text
*.json text
*.xml text
*.csproj text
*.sln text

# Config files
*.yml text
*.yaml text
*.md text

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows-specific
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.jar binary
*.class binary
